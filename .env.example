# =============================================================================
# Braza SSO — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# Server
PORT=8080
BASE_URL=https://sso.yourdomain.com
ENV=development

# Security
PEPPER=change-me-to-a-random-32-byte-string
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_ISSUER=https://sso.yourdomain.com
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=168h

# Cassandra
CASSANDRA_HOSTS=localhost
CASSANDRA_KEYSPACE=braza_sso
CASSANDRA_USERNAME=cassandra
CASSANDRA_PASSWORD=cassandra

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# SMTP (use SendGrid, Mailgun, or Resend relay)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
SMTP_FROM=noreply@yourdomain.com

# Google OAuth2 federation
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Keycloak OIDC federation (optional)
KEYCLOAK_ISSUER=https://keycloak.yourdomain.com/realms/your-realm
KEYCLOAK_CLIENT_ID=braza-sso
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret
